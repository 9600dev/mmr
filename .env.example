# IB Gateway credentials
TWS_USERID=
TWS_PASSWORD=

# Trading mode: paper or live
# Selects which account/port pair is active.
TRADING_MODE=paper

# IB account numbers (U... for live, DU... for paper)
IB_PAPER_ACCOUNT=
IB_LIVE_ACCOUNT=

# Timezone
TIME_ZONE=America/New_York

# VNC password for IB Gateway GUI (leave empty to disable VNC)
VNC_SERVER_PASSWORD=

# IB Gateway settings
TWS_ACCEPT_INCOMING=accept
READ_ONLY_API=no
TWOFA_TIMEOUT_ACTION=restart
RELOGIN_AFTER_TWOFA_TIMEOUT=yes
EXISTING_SESSION_DETECTED_ACTION=primaryoverride
AUTO_RESTART_TIME="11:59 PM"
ALLOW_BLIND_TRADING=no
